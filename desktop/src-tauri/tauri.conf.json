{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Album Mastering Studio",
  "version": "0.1.0",
  "identifier": "local.album-mastering-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build && npm run build:sidecars",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Album Mastering Studio",
        "width": 1440,
        "height": 940,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": [
      "resources/engine/album-master-engine.exe",
      "resources/ffmpeg/ffmpeg.exe",
      "resources/ffmpeg/ffprobe.exe"
    ]
  }
}
